--!strict
-- Persistent, bounded exactly-once journal for Cooper progression values.
--
-- Install as ReplicatedStorage.CooperGame.TransactionLedger. Operation ids are
-- always generated by authoritative server code; clients never supply them.
-- The journal is saved in the same profile payload as the value mutation, so a
-- successful DataStore write contains either both the value and its committed
-- record or neither of them.

local Ledger = {}

Ledger.VERSION = 1
Ledger.MAX_COMMITTED = 256
Ledger.MAX_PENDING = 32
Ledger.MAX_ROLLED_BACK = 64
Ledger.MAX_SEQUENCE = 2_000_000_000

local VALID_STATES = {
	Pending = true,
	Committed = true,
	RolledBack = true,
	NeedsReconciliation = true,
}

export type OperationState = "Pending" | "Committed" | "RolledBack" | "NeedsReconciliation"

export type OperationRecord = {
	id: string,
	sessionId: string,
	kind: string,
	userId: number,
	value: number,
	preconditionRevision: number,
	state: OperationState,
	createdAt: number,
	committedAt: number,
	result: { [string]: string | number | boolean },
}

export type Journal = {
	version: number,
	issuedHighWater: number?,
	pending: { OperationRecord },
	committed: { OperationRecord },
	rolledBack: { OperationRecord }?,
}

local function operationSequence(operationId: unknown): number?
	if type(operationId) ~= "string" then
		return nil
	end
	-- `server:` is retained for schema-12 operations created by the first M1
	-- build. `op:` is the canonical prefix for newly issued operations. Both
	-- carry the same profile-local monotonically increasing sequence.
	local raw = string.match(operationId, "^op:(%d+):")
		or string.match(operationId, "^server:(%d+):")
	local sequence = tonumber(raw)
	if not sequence or sequence < 1 or sequence > Ledger.MAX_SEQUENCE or sequence % 1 ~= 0 then
		return nil
	end
	return sequence
end

local function finiteInteger(value: unknown, default: number, minimum: number, maximum: number): number
	local numeric = tonumber(value)
	if not numeric or numeric ~= numeric or numeric == math.huge or numeric == -math.huge then
		return default
	end
	return math.clamp(math.floor(numeric + 0.5), minimum, maximum)
end

local function validBoundedString(value: unknown, minimum: number, maximum: number): boolean
	return type(value) == "string" and #value >= minimum and #value <= maximum
end

-- Build the stable, bounded kind used to find retries of one logical
-- server-authored transition. This deliberately accepts no spaces, control
-- characters, path syntax, or arbitrary client text.
function Ledger.logicalKind(prefix: unknown, rawKey: unknown): string?
	local key = tostring(rawKey or "")
	if type(prefix) ~= "string" or #prefix < 1 or #prefix > 32
		or #key < 1 or string.match(key, "^[%w_:%-]+$") == nil
	then
		return nil
	end
	local kind = prefix .. ":" .. key
	if #kind > 64 then
		return nil
	end
	return kind
end

local function sanitizeResult(raw: unknown): { [string]: string | number | boolean }
	local result: { [string]: string | number | boolean } = {}
	if type(raw) ~= "table" then
		return result
	end
	local count = 0
	for rawKey, rawValue in pairs(raw :: { [unknown]: unknown }) do
		if count >= 16 then
			break
		end
		if type(rawKey) == "string" and #rawKey >= 1 and #rawKey <= 40 then
			if type(rawValue) == "boolean" then
				result[rawKey] = rawValue
				count += 1
			elseif type(rawValue) == "string" and #rawValue <= 160 then
				result[rawKey] = rawValue
				count += 1
			elseif type(rawValue) == "number"
				and rawValue == rawValue
				and rawValue ~= math.huge
				and rawValue ~= -math.huge
			then
				result[rawKey] = rawValue
				count += 1
			end
		end
	end
	return result
end

local function sanitizeRecord(raw: unknown, expectedState: OperationState?): OperationRecord?
	if type(raw) ~= "table" then
		return nil
	end
	local source = raw :: { [string]: unknown }
	if not validBoundedString(source.id, 8, 160)
		or not validBoundedString(source.sessionId, 1, 160)
		or not validBoundedString(source.kind, 1, 64)
	then
		return nil
	end
	local state = type(source.state) == "string" and source.state or ""
	if not VALID_STATES[state] or (expectedState ~= nil and state ~= expectedState) then
		return nil
	end
	local userId = finiteInteger(source.userId, 0, 0, 9_007_199_254_740_991)
	if userId <= 0 then
		return nil
	end
	return {
		id = source.id :: string,
		sessionId = source.sessionId :: string,
		kind = source.kind :: string,
		userId = userId,
		value = finiteInteger(source.value, 0, -2_000_000_000, 2_000_000_000),
		preconditionRevision = finiteInteger(source.preconditionRevision, 0, 0, 2_000_000_000),
		state = state :: OperationState,
		createdAt = finiteInteger(source.createdAt, 0, 0, 4_102_444_800),
		committedAt = finiteInteger(source.committedAt, 0, 0, 4_102_444_800),
		result = sanitizeResult(source.result),
	}
end

local function appendTerminalUnique(
	committedTarget: { OperationRecord },
	rolledBackTarget: { OperationRecord },
	seen: { [string]: boolean },
	raw: unknown
)
	local record = sanitizeRecord(raw)
	if not record
		or (record.state ~= "Committed" and record.state ~= "RolledBack")
		or seen[record.id]
	then
		return
	end
	seen[record.id] = true
	local target = record.state == "Committed" and committedTarget or rolledBackTarget
	local maximum = record.state == "Committed" and Ledger.MAX_COMMITTED or Ledger.MAX_ROLLED_BACK
	table.insert(target, record)
	while #target > maximum do
		local removed = table.remove(target, 1)
		if removed then
			seen[removed.id] = nil
		end
	end
end

local function appendPendingUnique(
	target: { OperationRecord },
	seen: { [string]: boolean },
	raw: unknown
)
	local record = sanitizeRecord(raw)
	if not record
		or (record.state ~= "Pending" and record.state ~= "NeedsReconciliation")
		or seen[record.id]
	then
		return
	end
	seen[record.id] = true
	table.insert(target, record)
	while #target > Ledger.MAX_PENDING do
		local removed = table.remove(target, 1)
		if removed then
			seen[removed.id] = nil
		end
	end
end

local function appendRolledBackUnique(
	target: { OperationRecord },
	seen: { [string]: boolean },
	raw: unknown
)
	local record = sanitizeRecord(raw, "RolledBack")
	if not record or seen[record.id] then
		return
	end
	seen[record.id] = true
	table.insert(target, record)
	while #target > Ledger.MAX_ROLLED_BACK do
		local removed = table.remove(target, 1)
		if removed then
			seen[removed.id] = nil
		end
	end
end

local function maximumSequence(records: { OperationRecord }): number
	local maximum = 0
	for _, record in ipairs(records) do
		maximum = math.max(maximum, operationSequence(record.id) or 0)
	end
	return maximum
end

function Ledger.sanitize(raw: unknown): Journal
	local source: { [string]: unknown } = {}
	if type(raw) == "table" then
		source = raw :: { [string]: unknown }
	end
	local journal: Journal = {
		version = Ledger.VERSION,
		pending = {},
		committed = {},
	}
	local seen: { [string]: boolean } = {}
	local rolledBack = {}
	-- Observe valid source records before bounded arrays are trimmed. Otherwise
	-- an out-of-order highest sequence at the front could be physically evicted
	-- and silently lower the replay watermark during migration/sanitization.
	local issuedHighWater = finiteInteger(source.issuedHighWater, 0, 0, 2_000_000_000)
	if type(source.committed) == "table" then
		for _, record in ipairs(source.committed :: { unknown }) do
			local terminal = sanitizeRecord(record)
			if terminal and (terminal.state == "Committed" or terminal.state == "RolledBack") then
				issuedHighWater = math.max(issuedHighWater, operationSequence(terminal.id) or 0)
			end
			-- Early schema-12 builds co-mingled rollback tombstones with committed
			-- results. Migrate them into their separate bounded collection so they
			-- cannot reduce the guaranteed 256-result retention window.
			appendTerminalUnique(journal.committed, rolledBack, seen, record)
		end
	end
	if type(source.rolledBack) == "table" then
		for _, record in ipairs(source.rolledBack :: { unknown }) do
			local tombstone = sanitizeRecord(record, "RolledBack")
			if tombstone then
				issuedHighWater = math.max(issuedHighWater, operationSequence(tombstone.id) or 0)
			end
			appendRolledBackUnique(rolledBack, seen, record)
		end
	end
	-- Keep schema-11 migration output byte-for-byte compatible when no rollback
	-- history exists; the tombstone collection is created lazily.
	if #rolledBack > 0 then
		journal.rolledBack = rolledBack
	end
	if type(source.pending) == "table" then
		for _, record in ipairs(source.pending :: { unknown }) do
			local pending = sanitizeRecord(record)
			if pending and (pending.state == "Pending" or pending.state == "NeedsReconciliation") then
				issuedHighWater = math.max(issuedHighWater, operationSequence(pending.id) or 0)
			end
			appendPendingUnique(journal.pending, seen, record)
		end
	end
	issuedHighWater = math.max(
		issuedHighWater,
		maximumSequence(journal.pending),
		maximumSequence(journal.committed),
		maximumSequence(journal.rolledBack or {})
	)
	if issuedHighWater > 0 then
		journal.issuedHighWater = issuedHighWater
	end
	return journal
end

-- Terminal records provide a recoverable floor; issuedHighWater is the durable
-- monotonic source of truth even when bounded histories are trimmed or terminal
-- callbacks arrive out of issuance order.
function Ledger.finalizedHighWater(journal: Journal): number
	return math.max(
		maximumSequence(journal.committed),
		maximumSequence(journal.rolledBack or {})
	)
end

function Ledger.issuedHighWater(journal: Journal): number
	return math.max(
		finiteInteger(journal.issuedHighWater, 0, 0, 2_000_000_000),
		maximumSequence(journal.pending),
		Ledger.finalizedHighWater(journal)
	)
end

function Ledger.nextSequence(journal: Journal): number
	return Ledger.issuedHighWater(journal) + 1
end

function Ledger.issue(
	journal: Journal,
	sessionId: string,
	kind: string,
	userId: number,
	value: number,
	preconditionRevision: number,
	createdAt: number,
	nonce: string
): OperationRecord
	assert(validBoundedString(nonce, 8, 96), "Invalid authoritative operation nonce")
	local nextSequence = Ledger.nextSequence(journal)
	assert(nextSequence <= Ledger.MAX_SEQUENCE, "Operation sequence space is exhausted")
	local operationId = string.format(
		"op:%d:%d:%s",
		nextSequence,
		finiteInteger(userId, 0, 0, 9_007_199_254_740_991),
		nonce
	)
	return Ledger.makeRecord(
		operationId,
		sessionId,
		kind,
		userId,
		value,
		preconditionRevision,
		createdAt
	)
end

local function findRecord(records: { OperationRecord }, operationId: string): (number?, OperationRecord?)
	for index, record in ipairs(records) do
		if record.id == operationId then
			return index, record
		end
	end
	return nil, nil
end

function Ledger.lookup(journal: Journal, operationId: string): OperationRecord?
	local _, committed = findRecord(journal.committed, operationId)
	if committed then
		return committed
	end
	local _, rolledBack = findRecord(journal.rolledBack or {}, operationId)
	if rolledBack then
		return rolledBack
	end
	local _, pending = findRecord(journal.pending, operationId)
	return pending
end

function Ledger.makeRecord(
	operationId: string,
	sessionId: string,
	kind: string,
	userId: number,
	value: number,
	preconditionRevision: number,
	createdAt: number
): OperationRecord
	local record = sanitizeRecord({
		id = operationId,
		sessionId = sessionId,
		kind = kind,
		userId = userId,
		value = value,
		preconditionRevision = preconditionRevision,
		state = "Pending",
		createdAt = createdAt,
		committedAt = 0,
		result = {},
	}, "Pending")
	assert(record ~= nil, "Invalid authoritative operation record")
	return record :: OperationRecord
end

-- Returns false with the existing record for a retry. Callers must never apply
-- the value mutation again when false is returned.
function Ledger.begin(journal: Journal, record: OperationRecord): (boolean, OperationRecord)
	local existing = Ledger.lookup(journal, record.id)
	if existing then
		return false, existing
	end
	local sequence = operationSequence(record.id)
	if sequence and sequence <= Ledger.issuedHighWater(journal) then
		-- The detailed result may have been evicted, but its server-issued
		-- sequence remains at or below the newest retained terminal operation.
		-- Return the supplied record only as diagnostic context; never enqueue it.
		return false, record
	end
	assert(record.state == "Pending", "Only pending operations can begin")
	assert(#journal.pending < Ledger.MAX_PENDING, "Operation journal requires reconciliation before accepting more value changes")
	table.insert(journal.pending, record)
	if sequence then
		journal.issuedHighWater = math.max(
			finiteInteger(journal.issuedHighWater, 0, 0, 2_000_000_000),
			sequence
		)
	end
	return true, record
end

function Ledger.commit(
	journal: Journal,
	operationId: string,
	result: { [string]: string | number | boolean }?,
	committedAt: number
): OperationRecord?
	local _, alreadyCommitted = findRecord(journal.committed, operationId)
	if alreadyCommitted then
		return alreadyCommitted
	end
	local pendingIndex, pending = findRecord(journal.pending, operationId)
	if not pendingIndex or not pending then
		return nil
	end
	table.remove(journal.pending, pendingIndex)
	pending.state = "Committed"
	pending.committedAt = finiteInteger(committedAt, 0, 0, 4_102_444_800)
	pending.result = sanitizeResult(result)
	table.insert(journal.committed, pending)
	while #journal.committed > Ledger.MAX_COMMITTED do
		table.remove(journal.committed, 1)
	end
	return pending
end

function Ledger.markNeedsReconciliation(
	journal: Journal,
	operationId: string,
	reason: string?,
	code: string?
): OperationRecord?
	local _, pending = findRecord(journal.pending, operationId)
	if not pending then
		-- A DataStore response can be ambiguous after the in-memory operation was
		-- committed. Move that exact record back to the reconciliation queue; do
		-- not manufacture a second operation or re-run its value mutation.
		local committedIndex, committed = findRecord(journal.committed, operationId)
		if committedIndex and committed then
			table.remove(journal.committed, committedIndex)
			pending = committed
			table.insert(journal.pending, pending)
		end
	end
	if pending then
		pending.state = "NeedsReconciliation"
		local reconciledResult = sanitizeResult(pending.result)
		reconciledResult.reconciliationCode = if type(code) == "string" and code ~= ""
			then string.sub(code, 1, 40)
			else "SAVE_UNCONFIRMED"
		if type(reason) == "string" and reason ~= "" then
			reconciledResult.reconciliationReason = string.sub(reason, 1, 160)
		end
		pending.result = reconciledResult
	end
	return pending
end

function Ledger.sessionMatches(record: OperationRecord?, activeSessionId: string): boolean
	return record ~= nil
		and validBoundedString(activeSessionId, 1, 160)
		and record.sessionId == activeSessionId
end

function Ledger.rollback(
	journal: Journal,
	operationId: string,
	reason: string,
	rolledBackAt: number
): OperationRecord?
	local pendingIndex, pending = findRecord(journal.pending, operationId)
	if not pendingIndex or not pending then
		return nil
	end
	table.remove(journal.pending, pendingIndex)
	pending.state = "RolledBack"
	pending.committedAt = finiteInteger(rolledBackAt, 0, 0, 4_102_444_800)
	pending.result = sanitizeResult({
		code = "ROLLED_BACK",
		reason = string.sub(reason, 1, 160),
	})
	local rolledBack = journal.rolledBack or {}
	journal.rolledBack = rolledBack
	table.insert(rolledBack, pending)
	while #rolledBack > Ledger.MAX_ROLLED_BACK do
		table.remove(rolledBack, 1)
	end
	return pending
end

function Ledger.hasCommitted(journal: Journal, operationId: string, sessionId: string?): boolean
	local _, record = findRecord(journal.committed, operationId)
	return record ~= nil
		and record.state == "Committed"
		and (sessionId == nil or record.sessionId == sessionId)
end

return table.freeze(Ledger)
