local FakeClock = require("../support/FakeClock")
local PauseSet = require("../support/PauseSet")
local PausableDeadline = require("../support/PausableDeadline")

return function(test)
	test:test("counts duplicate reasons independently", function()
		local pauses = PauseSet.new()
		local first = pauses:acquire("Computer")
		local second = pauses:acquire("Computer")
		test:truthy(pauses:isPaused())
		test:equal(pauses:count(), 2)
		test:equal(pauses:reasonCount("Computer"), 2)
		pauses:release(first)
		test:truthy(pauses:isPaused())
		pauses:release(second)
		test:falsy(pauses:isPaused())
	end)

	test:test("does not underflow on duplicate or unknown resume", function()
		local pauses = PauseSet.new()
		local token = pauses:acquire("Dialogue")
		test:truthy(pauses:release(token))
		test:falsy(pauses:release(token))
		test:falsy(pauses:release("pause-999"))
		test:equal(pauses:count(), 0)
	end)

	test:test("freezes remaining time for a single pause", function()
		local clock = FakeClock.new(0)
		local deadline = PausableDeadline.new(clock, 100)
		clock:advance(25)
		local token = deadline:pause("Computer")
		clock:advance(50)
		test:equal(deadline:remaining(), 75)
		deadline:resume(token)
		test:equal(deadline:remaining(), 75)
		clock:advance(74.999)
		test:falsy(deadline:isExpired())
		clock:advance(0.001)
		test:truthy(deadline:isExpired())
	end)

	test:test("does not resume until every overlapping reason is released", function()
		local clock = FakeClock.new(0)
		local deadline = PausableDeadline.new(clock, 60)
		clock:advance(10)
		local computer = deadline:pause("Computer")
		clock:advance(5)
		local dialogue = deadline:pause("Dialogue")
		clock:advance(20)
		test:equal(deadline:remaining(), 50)
		deadline:resume(computer)
		test:truthy(deadline:isPaused())
		clock:advance(25)
		test:equal(deadline:remaining(), 50)
		deadline:resume(dialogue)
		test:falsy(deadline:isPaused())
		clock:advance(49)
		test:equal(deadline:remaining(), 1)
	end)

	test:test("an invalid resume cannot move the deadline", function()
		local clock = FakeClock.new(10)
		local deadline = PausableDeadline.new(clock, 30)
		local before = deadline:deadline()
		test:falsy(deadline:resume("not-issued"))
		test:equal(deadline:deadline(), before)
	end)
end
