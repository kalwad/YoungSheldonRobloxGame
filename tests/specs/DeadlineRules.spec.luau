local DeadlineRules = require("../support/DeadlineRules")

return function(test)
	test:test("keeps cycle one hidden, safe, and telemetry-only for 300 seconds", function()
		local rules = DeadlineRules.preReveal(1, 1, false)
		test:equal(rules.duration, 300)
		test:falsy(rules.visible)
		test:falsy(rules.failureEnabled)
		test:truthy(rules.storyOnly)
		test:falsy(rules.forceReveal)
	end)

	test:test("uses locked hidden budgets before the reveal", function()
		test:equal(DeadlineRules.preReveal(2, 1, false).duration, 240)
		test:equal(DeadlineRules.preReveal(3, 4, false).duration, 204)
		test:truthy(DeadlineRules.preReveal(2, 1, false).failureEnabled)
	end)

	test:test("forces the first task of cycle four when no natural timeout happened", function()
		local forced = DeadlineRules.preReveal(4, 1, false)
		test:truthy(forced.forceReveal)
		test:equal(forced.duration, 0)
		local laterTask = DeadlineRules.preReveal(4, 2, false)
		test:falsy(laterTask.forceReveal)
	end)

	test:test("uses exact post-reveal budgets and the 90 second floor", function()
		test:equal(DeadlineRules.postReveal(1).duration, 180)
		test:equal(DeadlineRules.postReveal(2).duration, 153)
		test:equal(DeadlineRules.postReveal(3).duration, 126)
		test:equal(DeadlineRules.postReveal(4).duration, 90)
		test:equal(DeadlineRules.postReveal(99).duration, 90)
	end)

	test:test("expires at the exact boundary rather than one frame later", function()
		local deadline = DeadlineRules.deadlineFrom(100.25, 90)
		test:falsy(DeadlineRules.isExpired(190.249999, deadline))
		test:truthy(DeadlineRules.isExpired(190.25, deadline))
	end)

	test:test("computes capped cash-only capture penalties and exempts story reveal", function()
		test:equal(DeadlineRules.capturePenalty(1000, 1, false), 0)
		test:equal(DeadlineRules.capturePenalty(1000, 2, false), 25)
		test:equal(DeadlineRules.capturePenalty(1000, 8, false), 175)
		test:equal(DeadlineRules.capturePenalty(1000, 50, false), 500)
		test:equal(DeadlineRules.capturePenalty(40, 50, false), 40)
		test:equal(DeadlineRules.capturePenalty(1000, 50, true), 0)
	end)
end
