local FakeClock = require("../support/FakeClock")
local SprintRules = require("../support/SprintRules")

local function nearlyEqual(test, actual, expected, epsilon)
	test:truthy(math.abs(actual - expected) <= (epsilon or 0.0001),
		string.format("expected %.6f near %.6f", actual, expected))
end

return function(test)
	test:test("six moving seconds exhaust sprint and restore walk speed", function()
		local sprint = SprintRules.new(FakeClock.new(0))
		local ok = sprint:setIntent(true)
		test:truthy(ok)
		sprint:tick(5.999, true)
		test:equal(sprint.speed, 22)
		test:truthy(sprint.stamina > 0)
		sprint:tick(0.001, true)
		test:equal(sprint.stamina, 0)
		test:truthy(sprint.exhausted)
		test:falsy(sprint.sprinting)
		test:equal(sprint.speed, 16)
	end)

	test:test("stationary sprint intent does not drain stamina", function()
		local sprint = SprintRules.new(FakeClock.new(0))
		sprint:setIntent(true)
		sprint:tick(20, false)
		test:equal(sprint.stamina, 6)
		test:falsy(sprint.sprinting)
		test:equal(sprint.speed, 16)
		sprint:tick(1, true)
		test:equal(sprint.stamina, 5)
		test:truthy(sprint.sprinting)
	end)

	test:test("release waits 0.8 seconds then regenerates at 1.5 per second", function()
		local sprint = SprintRules.new(FakeClock.new(0))
		sprint:setIntent(true)
		sprint:tick(2, true)
		sprint:setIntent(false)
		sprint:tick(0.8, false)
		test:equal(sprint.stamina, 4)
		sprint:tick(1, false)
		nearlyEqual(test, sprint.stamina, 5.5)
		test:truthy(sprint:hudVisible())
		sprint:tick(1 / 3, false)
		nearlyEqual(test, sprint.stamina, 6)
		test:falsy(sprint:hudVisible())
	end)

	test:test("exhaustion clears only after full gradual recovery", function()
		local sprint = SprintRules.new(FakeClock.new(0))
		sprint:setIntent(true)
		sprint:tick(6, true)
		sprint:tick(0.8, false)
		sprint:tick(3.999, false)
		test:truthy(sprint.exhausted)
		test:truthy(sprint.stamina < 6)
		sprint:tick(0.001, false)
		test:falsy(sprint.exhausted)
		test:equal(sprint.stamina, 6)
	end)

	test:test("locks and carry multiplier compose without granting sprint speed", function()
		local sprint = SprintRules.new(FakeClock.new(0))
		sprint:setMultiplier(0.75)
		sprint:setIntent(true)
		sprint:tick(1, true)
		nearlyEqual(test, sprint.speed, 16.5)
		sprint.locked = true
		sprint:tick(0, true)
		test:falsy(sprint.intent)
		test:falsy(sprint.sprinting)
		test:equal(sprint.speed, 0)
		test:equal(sprint.stamina, 5)
	end)

	test:test("server corrects local WalkSpeed edits", function()
		local sprint = SprintRules.new(FakeClock.new(0))
		test:equal(sprint:serverCorrect(999), 16)
		sprint:setIntent(true)
		sprint:tick(1, true)
		test:equal(sprint:serverCorrect(999), 22)
		test:equal(sprint:serverCorrect(22), 22)
	end)

	test:test("reset restores full isolated character state", function()
		local sprint = SprintRules.new(FakeClock.new(0))
		sprint:setIntent(true)
		sprint:tick(6, true)
		sprint.locked = true
		sprint:setMultiplier(0.5)
		sprint:resetCharacter()
		test:equal(sprint.stamina, 6)
		test:falsy(sprint.intent)
		test:falsy(sprint.sprinting)
		test:falsy(sprint.exhausted)
		test:falsy(sprint.locked)
		test:equal(sprint.speed, 16)
		test:equal(sprint.multiplier, 1)
		test:falsy(sprint:hudVisible())
	end)

	test:test("toggle spam never creates negative stamina or stacked speed", function()
		local sprint = SprintRules.new(FakeClock.new(0))
		for _ = 1, 100 do
			sprint:setIntent(true)
			sprint:tick(0.01, true)
			sprint:setIntent(false)
		end
		test:truthy(sprint.stamina >= 0)
		test:truthy(sprint.speed == 16 or sprint.speed == 22)
		test:truthy(sprint.stamina <= 6)
	end)
end
