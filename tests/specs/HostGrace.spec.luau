local FakeClock = require("../support/FakeClock")
local HostGraceScenario = require("../support/HostGraceScenario")

return function(test)
	test:test("duplicate host disconnect signals create one grace pause and deadline", function()
		local clock = FakeClock.new(100)
		local scenario = HostGraceScenario.new(clock, 101, 60)
		local ok, code = scenario:disconnectHost()
		test:truthy(ok)
		test:equal(code, "HostGraceStarted")
		local deadline = scenario.hostGraceDeadline

		ok, code = scenario:disconnectHost()
		test:truthy(ok)
		test:equal(code, "AlreadyInHostGrace")
		test:equal(scenario.hostGraceDeadline, deadline)
		test:equal(scenario.pauses:reasonCount("HostGrace"), 1)
		test:falsy(scenario:canMutate())
	end)

	test:test("host reconnect at 59.999 seconds resumes exactly once", function()
		local clock = FakeClock.new(0)
		local scenario = HostGraceScenario.new(clock, 101, 60)
		scenario:disconnectHost()
		clock:advance(59.999)
		local ok, code = scenario:rejoin(101)
		test:truthy(ok)
		test:equal(code, "Resumed")
		test:equal(scenario.resumeCount, 1)
		test:truthy(scenario:canMutate())
		ok, code = scenario:rejoin(101)
		test:falsy(ok)
		test:equal(code, "NoHostGrace")
		test:equal(scenario.resumeCount, 1)
	end)

	test:test("exact 60-second boundary closes and never resumes", function()
		local clock = FakeClock.new(0)
		local scenario = HostGraceScenario.new(clock, 101, 60)
		scenario:disconnectHost()
		clock:advance(60)
		local ok, code = scenario:rejoin(101)
		test:falsy(ok)
		test:equal(code, "HostGraceExpired")
		test:equal(scenario.phase, "Closing")
		test:equal(scenario.saveCount, 1)
		test:equal(scenario.returnCount, 1)
		test:equal(scenario.closeCount, 1)
		test:falsy(scenario:tick())
		test:equal(scenario.closeCount, 1)
	end)

	test:test("forged non-host rejoin cannot clear grace", function()
		local clock = FakeClock.new(0)
		local scenario = HostGraceScenario.new(clock, 101, 60)
		scenario:disconnectHost()
		local ok, code = scenario:rejoin(102)
		test:falsy(ok)
		test:equal(code, "NotHost")
		test:equal(scenario.pauses:reasonCount("HostGrace"), 1)
		test:falsy(scenario:canMutate())
	end)

	test:test("releasing host grace cannot clear another pause reason", function()
		local clock = FakeClock.new(0)
		local scenario = HostGraceScenario.new(clock, 101, 60)
		local loadingToken = scenario.pauses:acquire("ProfileLoading")
		scenario:disconnectHost()
		clock:advance(30)
		local ok = scenario:rejoin(101)
		test:truthy(ok)
		test:falsy(scenario:canMutate())
		test:equal(scenario.pauses:reasonCount("ProfileLoading"), 1)
		test:truthy(scenario.pauses:release(loadingToken))
		test:truthy(scenario:canMutate())
	end)
end
